# PostgreSQL connection string used by app.py and seed.py
# Local (Homebrew/system Postgres):
DATABASE_URL=postgresql://localhost/soc_dashboard

# Docker Compose (matches docker-compose.yml service name "db"):
# DATABASE_URL=postgresql://soc:soc@db:5432/soc_dashboard

# Flask
FLASK_ENV=development
PORT=8000

# Optional. Off by default. Set to 1/true only for local dev — it enables the
# Werkzeug debugger, which allows arbitrary code execution if ever exposed.
FLASK_DEBUG=0

# Optional. Bind address for `python app.py`; defaults to loopback (127.0.0.1).
# Set to 0.0.0.0 only when you intend to expose the port (e.g. in Docker).
HOST=127.0.0.1

# Required. Signs analyst login sessions; the app refuses to start without it.
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# Required to ingest alerts (POST /api/alerts sends this as the X-API-Key header).
#   python -c "import secrets; print(secrets.token_hex(32))"
ALERTS_API_KEY=

# Optional. Enables field-level encryption at rest for alert title/source_ip/
# description. Leave blank to store those as plaintext.
#   python -c "import secrets; print(secrets.token_hex(32))"
# WARNING: rotating this without re-encrypting existing rows makes previously
# encrypted alerts unreadable.
DB_ENCRYPTION_KEY=

# Optional. Delete alerts older than this many days at startup (0 = keep forever).
ALERT_RETENTION_DAYS=0
